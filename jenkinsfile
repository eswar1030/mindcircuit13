pipeline {
    agent any

    environment {
        // Your Jenkins credential ID storing the GitHub Username & Personal Access Token
        GITHUB_CRED_ID = 'jenkins-push-token-v2' 
    }

    stages {
        stage('CLONE SCM') {
            steps {
                echo 'Cloning Mc-app project code'
                git branch: 'main', url: 'https://github.com/eswar1030/mindcircuit13.git'
            }
        }

        stage('Build Artifact') {
            steps {
                echo 'Generating artifact with maven build tool'
                sh 'mvn clean install'
            }
        }

        stage('Update Deployment File') {
    steps {
        echo 'Update Deployment File'
        withCredentials([usernamePassword(
            credentialsId: 'jenkins-push-token-v2', 
            usernameVariable: 'GIT_USER', 
            passwordVariable: 'GIT_TOKEN'
        )]) {
            sh '''
                git config user.email "devopstraininghub@gmail.com"
                git config user.name "DevOps Bot"
                
                # Update image tag in deployment.yml
                sed -i 's/batch13:.*/batch13:17/g' deploymentfiles/deployment.yml
                
                # Stage ONLY the deployment manifest
                git add deploymentfiles/deployment.yml
                
                # '|| true' prevents pipeline failure if working tree is clean
                git commit -m "Update deployment image version" || true
                
                # Push to your fork
                git push https://${GIT_USER}:${GIT_TOKEN}@github.com/eswar1030/mindcircuit13.git HEAD:main
            '''
        }
    }
}

        stage('Deploy to tomcat') {
            steps {
                echo 'Deploying artifact to tomcat webserver'
                // Update with your actual Tomcat IP/Hostname and port
                deploy adapters: [tomcat9(credentialsId: 'tomcat', path: '', url: 'http://<YOUR_TOMCAT_IP>:8080')], contextPath: 'facebook-app', war: '**/*.war'
            }
        }
    }
}
